    <!-- JavaScript -->
    <script>
        // Simple Chart.js initialization
        const ctx = document.getElementById('progressChart')?.getContext('2d');
        if (ctx) {
            new Chart(ctx, {
                type: 'line',
                data: {
                    labels: ['Sen', 'Sel', 'Rab', 'Kam', 'Jum', 'Sab', 'Min'],
                    datasets: [{
                        label: 'Jam Belajar',
                        data: [1.5, 2, 1.8, 2.5, 2, 3, 2.2],
                        borderColor: '#4f46e5',
                        backgroundColor: 'rgba(79, 70, 229, 0.1)',
                        tension: 0.4,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            display: false
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: true,
                            max: 4
                        }
                    }
                }
            });
        }

        // DOM Elements
        const chatMessages = document.getElementById('chatMessages');
        const messageInput = document.getElementById('messageInput');
        const sendBtn = document.getElementById('sendBtn');
        const fiksiToggle = document.getElementById('fiksiMode');
        const modeFiksi = document.getElementById('modeFiksi');
        const modeSerius = document.getElementById('modeSerius');
        const openDashboard = document.getElementById('openDashboard');
        const closeDashboard = document.getElementById('closeDashboard');
        const parentDashboard = document.getElementById('parentDashboard');
        const uploadBtn = document.getElementById('uploadBtn');
        const uploadPreview = document.getElementById('uploadPreview');
        const removePreview = document.getElementById('removePreview');
        const timeWarning = document.getElementById('timeWarning');
        const typingIndicator = document.getElementById('typingIndicator');
        const timeRange = document.getElementById('timeRange');
        const timeLimit = document.getElementById('timeLimit');

        // Variables
        let isFiksiMode = true;
        let currentScientist = 'einstein';
        let uploadedImage = null;

        // Auto-resize textarea
        messageInput.addEventListener('input', function() {
            this.style.height = 'auto';
            this.style.height = (this.scrollHeight) + 'px';
        });

        // Send message function
        function sendMessage() {
            const message = messageInput.value.trim();
            if (message || uploadedImage) {
                // Add user message
                addMessage(message, 'user', uploadedImage);
                
                // Clear input
                messageInput.value = '';
                messageInput.style.height = 'auto';
                
                // Clear upload preview
                if (uploadedImage) {
                    uploadPreview.style.display = 'none';
                    uploadedImage = null;
                }
                
                // Show typing indicator
                typingIndicator.style.display = 'flex';
                
                // Simulate AI response after delay
                setTimeout(() => {
                    typingIndicator.style.display = 'none';
                    
                    // Generate AI response based on mode
                    let response = '';
                    if (isFiksiMode) {
                        response = generateFiksiResponse(message);
                    } else {
                        response = generateSeriusResponse(message);
                    }
                    
                    addMessage(response, 'ai');
                }, 1500);
            }
        }

        // Add message to chat
        function addMessage(text, type, image = null) {
            const messageDiv = document.createElement('div');
            messageDiv.className = `message ${type === 'user' ? 'user' : ''}`;
            
            const time = new Date().toLocaleTimeString('id-ID', { hour: '2-digit', minute: '2-digit' });
            
            let avatarHtml = '';
            if (type === 'user') {
                avatarHtml = '<img src="https://ui-avatars.com/api/?name=Andi&background=4F46E5&color=fff" alt="User">';
            } else {
                avatarHtml = '<i class="fas fa-user-astronaut"></i>';
            }
            
            let messageContent = text;
            if (type === 'ai' && isFiksiMode) {
                messageContent = `
                    <div class="fiksi-badge">
                        <i class="fas fa-magic"></i> Mode Fiksi
                    </div>
                    ${text}
                `;
            }
            
            let imageHtml = '';
            if (image) {
                imageHtml = `
                    <div class="message-image">
                        <img src="${image}" alt="Uploaded image">
                        <div class="image-meta">Uploaded image</div>
                    </div>
                `;
            }
            
            messageDiv.innerHTML = `
                <div class="message-avatar">
                    ${avatarHtml}
                </div>
                <div class="message-content">
                    <div class="message-header">
                        <span class="sender">${type === 'user' ? 'Andi' : 'Albert Einstein'}</span>
                        <span class="time">${time}</span>
                    </div>
                    <div class="message-text">
                        <p>${messageContent}</p>
                        ${imageHtml}
                    </div>
                </div>
            `;
            
            chatMessages.appendChild(messageDiv);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        // Generate fiksi response
        function generateFiksiResponse(message) {
            const responses = [
                "Wah, pertanyaan yang imajinatif! Kalau aku jadi penyihir, aku akan mengubah rumus E=mc² menjadi 'Energi = keajaiban × coklat²'! 🪄",
                "Menarik! Bayangkan kalau gravitasi bisa dimatikan seperti saklar. Kita semua akan melayang-layang seperti balon! 🎈",
                "Dalam dunia fiksi, aku bisa membuat mesin waktu dari cermin dan sinar matahari. Mau jalan-jalan ke masa depan? ⏰",
                "Hmm... Kalau kucing Schrödinger bisa bicara, dia akan bilang 'Aku hidup DAN mati sekaligus, messi banget!' 😺"
            ];
            return responses[Math.floor(Math.random() * responses.length)];
        }

        // Generate serius response
        function generateSeriusResponse(message) {
            const responses = [
                "Berdasarkan teori relativitas, waktu bergerak lebih lambat di dekat objek bermassa besar. Ini sudah dibuktikan dengan eksperimen.",
                "Rumus E=mc² menunjukkan bahwa massa dan energi itu setara. Jumlah energi yang tersimpan dalam satu kilogram massa sangat besar!",
                "Cahaya bergerak dengan kecepatan konstan 299.792.458 meter per detik di ruang hampa, tidak peduli seberapa cepat pengamat bergerak.",
                "Gravitasi bukan gaya tarik-menarik biasa, melainkan lengkungan ruang-waktu yang disebabkan oleh massa dan energi."
            ];
            return responses[Math.floor(Math.random() * responses.length)];
        }

        // Event Listeners
        sendBtn.addEventListener('click', sendMessage);

        messageInput.addEventListener('keypress', function(e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });

        // Mode toggle
        fiksiToggle.addEventListener('change', function(e) {
            isFiksiMode = e.target.checked;
            modeFiksi.classList.toggle('active', isFiksiMode);
            modeSerius.classList.toggle('active', !isFiksiMode);
        });

        modeFiksi.addEventListener('click', function() {
            isFiksiMode = true;
            fiksiToggle.checked = true;
            modeFiksi.classList.add('active');
            modeSerius.classList.remove('active');
        });

        modeSerius.addEventListener('click', function() {
            isFiksiMode = false;
            fiksiToggle.checked = false;
            modeSerius.classList.add('active');
            modeFiksi.classList.remove('active');
        });

        // Dashboard toggle
        openDashboard.addEventListener('click', function() {
            parentDashboard.style.display = 'flex';
        });

        closeDashboard.addEventListener('click', function() {
            parentDashboard.style.display = 'none';
        });

        // Upload image simulation
        uploadBtn.addEventListener('click', function() {
            // Simulate file upload
            uploadedImage = 'https://picsum.photos/400/300?random=' + Math.random();
            document.getElementById('previewImage').src = uploadedImage;
            document.getElementById('fileName').textContent = 'image_' + Date.now() + '.jpg';
            uploadPreview.style.display = 'flex';
        });

        removePreview.addEventListener('click', function() {
            uploadPreview.style.display = 'none';
            uploadedImage = null;
        });

        // Time range display
        timeRange.addEventListener('input', function() {
            timeLimit.textContent = this.value + ' jam';
        });

        // Scientist selection
        document.querySelectorAll('.scientist-card').forEach(card => {
            card.addEventListener('click', function() {
                document.querySelectorAll('.scientist-card').forEach(c => c.classList.remove('active'));
                this.classList.add('active');
                
                // Change scientist info in header
                const scientistName = this.querySelector('h4').textContent;
                const headerTitle = document.querySelector('.scientist-active-info h2');
                headerTitle.innerHTML = `<span class="scientist-icon"><i class="fas ${getScientistIcon(scientistName)}"></i></span> ${scientistName}`;
                
                // Add system message
                addMessage(`Halo! Aku ${scientistName}. Ada yang ingin kamu tanyakan?`, 'ai');
            });
        });

        function getScientistIcon(name) {
            const icons = {
                'Albert Einstein': 'fa-user-astronaut',
                'Isaac Newton': 'fa-apple-alt',
                'Nikola Tesla': 'fa-bolt',
                'Marie Curie': 'fa-vial',
                'Niels Bohr': 'fa-atom'
            };
            return icons[name] || 'fa-flask';
        }

        // Hide time warning by default (demo)
        timeWarning.style.display = 'none';
    </script>

    <!-- Chart.js for dashboard -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
