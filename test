<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>IlmuwanAI - Chat dengan Para Jenius</title>

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .app-container {
            width: 1400px;
            max-width: 98%;
            height: 90vh;
            background: white;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
            display: flex;
            overflow: hidden;
            position: relative;
        }

        /* Sidebar Styles */
        .sidebar {
            width: 320px;
            background: #f8faff;
            border-right: 1px solid #e0e7ff;
            display: flex;
            flex-direction: column;
            padding: 20px;
        }

        .sidebar-header {
            margin-bottom: 24px;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            color: #1e1b4b;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .logo i {
            color: #4f46e5;
            font-size: 28px;
        }

        .logo span {
            color: #4f46e5;
        }

        .profile-section {
            background: white;
            border-radius: 16px;
            padding: 16px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        }

        .user-profile {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 12px;
        }

        .user-profile img {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            object-fit: cover;
        }

        .user-info {
            flex: 1;
        }

        .user-name {
            font-weight: 600;
            color: #1e293b;
            display: block;
        }

        .user-age {
            font-size: 12px;
            color: #64748b;
        }

        .btn-switch-profile {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            border: 1px solid #e2e8f0;
            background: white;
            color: #64748b;
            cursor: pointer;
            transition: all 0.2s;
        }

        .btn-switch-profile:hover {
            background: #f1f5f9;
            color: #4f46e5;
        }

        .parent-control-badge {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 12px;
            background: #f0f9ff;
            border-radius: 12px;
            font-size: 13px;
            color: #0369a1;
        }

        .parent-control-badge i {
            font-size: 14px;
        }

        .btn-parent-dashboard {
            margin-left: auto;
            background: none;
            border: none;
            color: #0369a1;
            cursor: pointer;
            opacity: 0.7;
        }

        .btn-parent-dashboard:hover {
            opacity: 1;
        }

        /* Scientists List */
        .scientists-list {
            flex: 1;
            overflow-y: auto;
            margin: 20px 0;
        }

        .scientists-list h3 {
            font-size: 14px;
            font-weight: 600;
            color: #475569;
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            cursor: pointer;
            padding: 0 4px;
        }

        .scientist-card {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            border-radius: 14px;
            background: white;
            margin-bottom: 8px;
            cursor: pointer;
            transition: all 0.2s;
            border: 1px solid transparent;
        }

        .scientist-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.1);
            border-color: #4f46e5;
        }

        .scientist-card.active {
            background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);
            border-color: #4f46e5;
        }

        .scientist-card.active .scientist-info h4,
        .scientist-card.active .scientist-info p,
        .scientist-card.active .time-badge {
            color: white;
        }

        .scientist-avatar {
            width: 48px;
            height: 48px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }

        .scientist-avatar.einstein {
            background: linear-gradient(135deg, #4299e1, #667eea);
            color: white;
        }

        .scientist-avatar.newton {
            background: linear-gradient(135deg, #48bb78, #38a169);
            color: white;
        }

        .scientist-avatar.bohr {
            background: linear-gradient(135deg, #ed8936, #dd6b20);
            color: white;
        }

        .scientist-avatar.tesla {
            background: linear-gradient(135deg, #f56565, #c53030);
            color: white;
        }

        .scientist-avatar.curie {
            background: linear-gradient(135deg, #9f7aea, #805ad5);
            color: white;
        }

        .scientist-info {
            flex: 1;
        }

        .scientist-info h4 {
            font-size: 15px;
            font-weight: 600;
            color: #1e293b;
            margin-bottom: 2px;
        }

        .scientist-info p {
            font-size: 12px;
            color: #64748b;
        }

        .time-badge {
            font-size: 12px;
            color: #64748b;
            background: rgba(255, 255, 255, 0.2);
            padding: 4px 8px;
            border-radius: 20px;
            display: flex;
            align-items: center;
            gap: 4px;
        }

        .sidebar-footer {
            border-top: 1px solid #e2e8f0;
            padding-top: 16px;
        }

        .daily-reset {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #64748b;
            font-size: 13px;
            margin-bottom: 12px;
        }

        .fiksi-mode-indicator {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #4f46e5;
            font-size: 13px;
            font-weight: 500;
        }

        /* Toggle Switch */
        .switch {
            position: relative;
            display: inline-block;
            width: 44px;
            height: 22px;
            margin-left: auto;
        }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #cbd5e1;
            transition: .3s;
            border-radius: 22px;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 18px;
            width: 18px;
            left: 2px;
            bottom: 2px;
            background-color: white;
            transition: .3s;
            border-radius: 50%;
        }

        input:checked + .slider {
            background-color: #4f46e5;
        }

        input:checked + .slider:before {
            transform: translateX(22px);
        }

        /* Main Chat Area */
        .chat-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: white;
        }

        .chat-header {
            padding: 20px 24px;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .scientist-active-info h2 {
            font-size: 20px;
            font-weight: 600;
            color: #1e293b;
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 4px;
        }

        .scientist-icon {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, #4299e1, #667eea);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-size: 20px;
        }

        .scientist-status {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .status-badge {
            display: flex;
            align-items: center;
            gap: 4px;
            font-size: 13px;
        }

        .status-badge.online {
            color: #10b981;
        }

        .status-badge i {
            font-size: 10px;
        }

        .time-remaining {
            font-size: 13px;
            color: #64748b;
        }

        .chat-actions {
            display: flex;
            gap: 8px;
        }

        .btn-mode, .btn-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            border: 1px solid #e2e8f0;
            background: white;
            color: #64748b;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 16px;
        }

        .btn-mode:hover, .btn-icon:hover {
            background: #f1f5f9;
            color: #4f46e5;
            border-color: #4f46e5;
        }

        .btn-mode.active {
            background: #4f46e5;
            color: white;
            border-color: #4f46e5;
        }

        /* Chat Messages */
        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 24px;
            display: flex;
            flex-direction: column;
            gap: 20px;
            background: #fafaff;
        }

        .message {
            display: flex;
            gap: 12px;
            max-width: 80%;
        }

        .message.user {
            margin-left: auto;
            flex-direction: row-reverse;
        }

        .message-avatar {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #475569;
            flex-shrink: 0;
            overflow: hidden;
        }

        .message-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .message-content {
            flex: 1;
        }

        .message-header {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 4px;
        }

        .message.user .message-header {
            justify-content: flex-end;
        }

        .sender {
            font-weight: 600;
            font-size: 14px;
            color: #1e293b;
        }

        .time {
            font-size: 12px;
            color: #94a3b8;
        }

        .message-text {
            background: white;
            padding: 14px 16px;
            border-radius: 18px;
            border-top-left-radius: 4px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
            color: #334155;
            line-height: 1.5;
            font-size: 14px;
        }

        .message.user .message-text {
            background: #4f46e5;
            color: white;
            border-top-left-radius: 18px;
            border-top-right-radius: 4px;
        }

        .message-text p {
            margin-bottom: 8px;
        }

        .message-text p:last-child {
            margin-bottom: 0;
        }

        .fiksi-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: #fef3c7;
            color: #d97706;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
            margin-bottom: 10px;
        }

        .ilmu-note {
            background: #f0f9ff;
            padding: 10px 12px;
            border-radius: 12px;
            margin-top: 10px;
            font-size: 13px;
            color: #0369a1;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .message-image {
            margin-top: 10px;
            border-radius: 12px;
            overflow: hidden;
            border: 1px solid #e2e8f0;
        }

        .message-image img {
            width: 100%;
            max-height: 200px;
            object-fit: cover;
        }

        .image-meta {
            padding: 6px 12px;
            background: #f8fafc;
            font-size: 12px;
            color: #64748b;
        }

        .analysis-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            background: #4f46e5;
            color: white;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 12px;
            margin-bottom: 10px;
        }

        .analysis-stats {
            background: #f8fafc;
            border-radius: 12px;
            padding: 12px;
            margin: 10px 0;
        }

        .stat-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 6px 0;
            border-bottom: 1px solid #e2e8f0;
        }

        .stat-item:last-child {
            border-bottom: none;
        }

        .color-dot {
            display: inline-block;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            margin-right: 6px;
        }

        .mt-2 {
            margin-top: 8px;
        }

        /* Input Area */
        .chat-input-area {
            padding: 20px 24px;
            border-top: 1px solid #e2e8f0;
            background: white;
        }

        .input-tools {
            display: flex;
            gap: 8px;
            margin-bottom: 12px;
        }

        .tool-btn {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            background: white;
            color: #64748b;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 14px;
        }

        .tool-btn:hover {
            background: #f1f5f9;
            color: #4f46e5;
        }

        .input-wrapper {
            display: flex;
            gap: 12px;
            align-items: flex-end;
        }

        .input-wrapper textarea {
            flex: 1;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 14px 18px;
            font-family: inherit;
            font-size: 14px;
            resize: none;
            max-height: 120px;
            outline: none;
            transition: all 0.2s;
        }

        .input-wrapper textarea:focus {
            border-color: #4f46e5;
            box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
        }

        .send-btn {
            width: 48px;
            height: 48px;
            border-radius: 16px;
            background: #4f46e5;
            border: none;
            color: white;
            font-size: 18px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .send-btn:hover {
            background: #4338ca;
            transform: scale(1.05);
        }

        .upload-preview {
            margin-top: 12px;
            padding: 12px;
            background: #f8fafc;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .upload-preview img {
            width: 60px;
            height: 60px;
            border-radius: 8px;
            object-fit: cover;
        }

        .preview-info {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .remove-preview {
            width: 28px;
            height: 28px;
            border-radius: 50%;
            border: none;
            background: #fee2e2;
            color: #ef4444;
            cursor: pointer;
        }

        .time-warning {
            margin-top: 12px;
            padding: 10px 16px;
            background: #fff3cd;
            color: #856404;
            border-radius: 12px;
            font-size: 13px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* Parent Dashboard */
        .parent-dashboard {
            position: absolute;
            top: 0;
            right: 0;
            width: 400px;
            height: 100%;
            background: white;
            box-shadow: -5px 0 20px rgba(0, 0, 0, 0.1);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            animation: slideIn 0.3s ease;
        }

        @keyframes slideIn {
            from { transform: translateX(100%); }
            to { transform: translateX(0); }
        }

        .dashboard-header {
            padding: 20px;
            border-bottom: 1px solid #e2e8f0;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .dashboard-header h3 {
            display: flex;
            align-items: center;
            gap: 8px;
            color: #1e293b;
        }

        .close-dashboard {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            background: white;
            cursor: pointer;
        }

        .dashboard-content {
            flex: 1;
            overflow-y: auto;
            padding: 20px;
        }

        .child-selector {
            margin-bottom: 20px;
        }

        .child-selector select {
            width: 100%;
            padding: 10px;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            margin-top: 6px;
            font-family: inherit;
        }

        .summary-card, .activities-card, .controls-card, .report-card {
            background: #f8fafc;
            border-radius: 16px;
            padding: 16px;
            margin-bottom: 20px;
        }

        .summary-card h4, .activities-card h4, .controls-card h4, .report-card h4 {
            margin-bottom: 16px;
            color: #1e293b;
        }

        .summary-stats {
            display: flex;
            justify-content: space-around;
        }

        .stat {
            text-align: center;
        }

        .stat .stat-value {
            font-size: 20px;
            font-weight: 600;
            color: #4f46e5;
            display: block;
        }

        .activity-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid #e2e8f0;
        }

        .activity-item:last-child {
            border-bottom: none;
        }

        .activity-item.warning i {
            color: #f59e0b;
        }

        .activity-item i {
            width: 20px;
        }

        .activity-detail {
            flex: 1;
        }

        .activity-text {
            font-size: 14px;
            color: #334155;
            display: block;
        }

        .activity-time {
            font-size: 12px;
            color: #94a3b8;
        }

        .control-item {
            margin-bottom: 16px;
        }

        .control-item label {
            display: block;
            margin-bottom: 6px;
            font-size: 14px;
        }

        .control-item input[type="range"] {
            width: 100%;
        }

        .switch-label {
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .btn-save-controls {
            width: 100%;
            padding: 12px;
            background: #4f46e5;
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 12px;
        }

        .btn-download-report {
            width: 100%;
            padding: 12px;
            background: #10b981;
            color: white;
            border: none;
            border-radius: 12px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-top: 16px;
        }

        /* Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: #f1f5f9;
        }

        ::-webkit-scrollbar-thumb {
            background: #94a3b8;
            border-radius: 3px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #64748b;
        }
    </style>
</head>
<body>
    <div class="app-container">
        <!-- Sidebar Kiri -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <h1 class="logo">
                    <i class="fas fa-robot"></i>
                    Ilmuwan<span>AI</span>
                </h1>

                <div class="profile-section">
                    <div class="user-profile">
                        <img src="https://ui-avatars.com/api/?name=Andi&background=4F46E5&color=fff" alt="Profile">
                        <div class="user-info">
                            <span class="user-name">Andi</span>
                            <span class="user-age">8 tahun • SD</span>
                        </div>
                        <button class="btn-switch-profile">
                            <i class="fas fa-exchange-alt"></i>
                        </button>
                    </div>

                    <div class="parent-control-badge">
                        <i class="fas fa-shield-alt"></i>
                        <span>Parent Control Active</span>
                        <button class="btn-parent-dashboard" id="openDashboard">
                            <i class="fas fa-cog"></i>
                        </button>
                    </div>
                </div>
            </div>

            <!-- Daftar Ilmuwan -->
            <div class="scientists-list">
                <h3>Chat dengan Ilmuwan <i class="fas fa-chevron-down"></i></h3>

                <div class="scientist-card active" data-scientist="einstein">
                    <div class="scientist-avatar einstein">
                        <i class="fas fa-user-astronaut"></i>
                    </div>
                    <div class="scientist-info">
                        <h4>Albert Einstein</h4>
                        <p>Fisika Modern • Relativitas</p>
                    </div>
                    <div class="time-badge">
                        <i class="far fa-clock"></i>
                        <span>45/60</span>
                    </div>
                </div>

                <div class="scientist-card" data-scientist="newton">
                    <div class="scientist-avatar newton">
                        <i class="fas fa-apple-alt"></i>
                    </div>
                    <div class="scientist-info">
                        <h4>Isaac Newton</h4>
                        <p>Fisika Klasik • Gravitasi</p>
                    </div>
                    <div class="time-badge">
                        <i class="far fa-clock"></i>
                        <span>60/60</span>
                    </div>
                </div>

                <div class="scientist-card" data-scientist="tesla">
                    <div class="scientist-avatar tesla">
                        <i class="fas fa-bolt"></i>
                    </div>
                    <div class="scientist-info">
                        <h4>Nikola Tesla</h4>
                        <p>Listrik • Elektromagnetik</p>
                    </div>
                    <div class="time-badge">
                        <i class="far fa-clock"></i>
                        <span>60/60</span>
                    </div>
                </div>

                <div class="scientist-card" data-scientist="curie">
                    <div class="scientist-avatar curie">
                        <i class="fas fa-vial"></i>
                    </div>
                    <div class="scientist-info">
                        <h4>Marie Curie</h4>
                        <p>Radioaktivitas • Kimia</p>
                    </div>
                    <div class="time-badge">
                        <i class="far fa-clock"></i>
                        <span>60/60</span>
                    </div>
                </div>

                <div class="scientist-card" data-scientist="bohr">
                    <div class="scientist-avatar bohr">
                        <i class="fas fa-atom"></i>
                    </div>
                    <div class="scientist-info">
                        <h4>Niels Bohr</h4>
